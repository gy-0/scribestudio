# New Volcengine / Doubao Speech console credential (some accounts only need API Key / App Key)
# VOLCENGINE_API_KEY=your_api_key_or_app_key_here

# App ID + Access Token credentials from the Doubao Speech / Volcengine console
VOLCENGINE_APP_ID=your_app_id_here
VOLCENGINE_ACCESS_TOKEN=your_access_token_here

# Optional override. Defaults:
# flash mode: volc.bigasr.auc_turbo
# standard mode: volc.seedasr.auc
# VOLCENGINE_RESOURCE_ID=volc.bigasr.auc_turbo
